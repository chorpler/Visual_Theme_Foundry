{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": "static/js",
    "outDir": "static/js/dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["static/js/**/*.ts"],
  "exclude": ["static/js/dist"]
}
